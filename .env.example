# Bearden-Intake — Environment Configuration
# Copy to .env and fill in values
# SEC-001: Secrets management

# ── Anthropic API Key ────────────────────────────────────────────────────
# Required for document extraction (Claude vision).
# Get yours at: https://console.anthropic.com/settings/keys
# Can also be set via the Settings page in the UI.
# NEVER commit the real key.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Flask ────────────────────────────────────────────────────────────────
# Secret key for session cookies. Auto-generated if not set.
# FLASK_SECRET_KEY=your-random-secret

# ── Server ───────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=5050
