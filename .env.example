# Bearden Document Intake — Environment Configuration
# Copy to .env and fill in values

# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Optional ────────────────────────────────────────────────────────────────
# PORT=5050

# ─── Auth (RALPH-REFACTOR-003) ───────────────────────────────────────────────
# Auth mode: off (default), shared-secret, or pin
AUTH_MODE=off

# For shared-secret mode:
# LITE_SHARED_SECRET=your-secret-here

# For pin mode (use LITE_PIN_HASH in production):
# LITE_PIN_HASH=sha256-hex-hash-of-pin
# LITE_PIN_PLAINTEXT=1234  # dev-only fallback
